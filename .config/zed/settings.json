          "list_directory": true,
          "grep": true,
          "get_code_actions": false,
          "go_to_definition": true,
          "find_references": true,
          "find_path": true,
          "apply_code_action": false
        },
        "enable_all_context_servers": false,
        "context_servers": {},
        "default_model": {
          "provider": "ollama",
          "model": "qwen2.5-coder:7b",
          "enable_thinking": false
        }
      },
      "plan": {
        "default_model": {
          "provider": "ollama",
          "model": "qwen2.5-coder:7b",
          "enable_thinking": false
        },
        "name": "Plan",
        "tools": {
          "list_directory": true,
          "grep": true,
          "get_code_actions": false,
          "go_to_definition": true,
          "find_references": true,
          "find_path": true,
          "apply_code_action": false
        },
        "enable_all_context_servers": false,
        "context_servers": {}
      }
    },
    "default_model": {
      "provider": "ollama",
      "model": "qwen2.5-coder:7b",
      "enable_thinking": false
    },
    "favorite_models": [],
    "model_parameters": []
  },
  "language_models": {
    "ollama": {
      "api_url": "http://100.78.238.25:11434"
    }
  },
  "edit_predictions": {
    "provider": "ollama"
  },
  "proxy": "",
  "project_panel": {
    "default_width": 300.0,
    "dock": "left"
  },
  "disable_ai": false,
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
    "anthropic_retention": false
  },
  "terminal": {
    "font_size": 16.0,
    "font_family": "monospace"
  },
  "base_keymap": "VSCode",
  "tab_bar": {
    "show": false
  },
  "mouse_wheel_zoom": true,
  "minimap": {
    "show": "never"
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000
    }
  },
  "buffer_font_family": "JetBrains Mono NL",
  "file_types": {
    "dotenv": [
      ".env*"
    ]
  },
  "auto_indent_on_paste": true,
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
